@page "/"
@using MusicTeacher.Shared.Lessons
@using MusicTeacher.Shared.MusicTheory
@using MusicTeacher.Shared.Progress
@inject HttpClient Http
@inject IProgressStore ProgressStore
@inject MusicAudioService Audio
@inject AppLocalizer Localizer
@inject IJSRuntime JS

<PageTitle>@Localizer["AppTitle"]</PageTitle>

@if (unlockToast is not null)
{
    <UnlockToast Title="@Localizer["UnlockToastTitle"]"
                 Message="@unlockToast.Message"
                 BadgeTitle="@unlockToast.BadgeTitle"
                 BadgeDescription="@unlockToast.BadgeDescription"
                 BadgeIcon="@unlockToast.BadgeIcon"
                 DismissLabel="@Localizer["DismissToast"]"
                 OnDismiss="DismissUnlockToast" />
}

@if (!hasStarted)
{
    <section class="start-screen">
        <div class="start-card">
            <div class="profile-header-card">
                <div class="profile-avatar-area">
                    <AvatarPortrait Avatar="@selectedAvatar" Size="large" IsAnimated="true" />
                    <button class="customize-trigger-button" type="button" @onclick="OpenCustomizer">
                        🎨 @Localizer["CustomizerEditButton"]
                    </button>
                </div>
                <div class="profile-details-area">
                    <div class="lesson-kicker">@(lesson is null ? string.Empty : Localizer["TrebleClefKicker"])</div>
                    <h1>@Localizer["ProfileWelcome"]</h1>
                    <p class="profile-welcome-intro">@Localizer["StartScreenIntro"]</p>
                    <div class="profile-meta-badges">
                        <span class="meta-badge">
                            🌐 @(Localizer.CurrentCulture.Name.StartsWith("nl", StringComparison.OrdinalIgnoreCase) ? "Nederlands" : "English")
                        </span>
                        <span class="meta-badge">
                            🎵 @(UseAlphabeticalNoteNames ? Localizer["NoteNameModeAlphabetical"] : Localizer["NoteNameModeFixedDo"])
                        </span>
                    </div>
                </div>
            </div>

            <div class="start-options" aria-label="@Localizer["PracticeModeLabel"]">
                <button class="start-option-card"
                        type="button"
                        @onclick="() => StartPractice(PracticeMode.FreeExplore)">
                    <strong>@Localizer["FreeExploreMode"]</strong>
                    <small>@Localizer["FreeExploreDescription"]</small>
                </button>
                <button class="start-option-card is-primary"
                        type="button"
                        @onclick="() => StartPractice(PracticeMode.LearningPath)">
                    <strong>@Localizer["LearningMode"]</strong>
                    <small>@Localizer["LearningModeDescription"]</small>
                </button>
                <button class="start-option-card"
                        type="button"
                        @onclick="() => StartPractice(PracticeMode.Theory)">
                    <strong>@Localizer["TheoryMode"]</strong>
                    <small>@Localizer["TheoryModeDescription"]</small>
                </button>
            </div>
        </div>
    </section>
}
else if (practiceMode == PracticeMode.Theory)
{
    <section class="theory-stage">
        <div class="lesson-panel theory-panel">
            <div class="avatar-chip" aria-label="@Localizer["SelectedAvatarLabel"]">
                <AvatarPortrait Avatar="@selectedAvatar" Size="small" />
            </div>
            <div class="lesson-kicker">@Localizer["TheoryKicker"]</div>
            <h1>@Localizer["TheoryTitle"]</h1>

            <button class="back-to-start-button" type="button" @onclick="ReturnToStart">
                @Localizer["BackToStart"]
            </button>

            <div class="level-card" aria-live="polite">
                <div class="level-card-header">
                    <span>@Localizer.Format("TheoryLevelLabel", CurrentTheoryPage.Level)</span>
                    <span>@Localizer.Format("TheoryPageCounter", theoryPageIndex + 1, AvailableTheoryPages.Count)</span>
                </div>
                <strong>@CurrentTheoryTitle</strong>
                <small>@CurrentTheorySummary</small>
            </div>
        </div>

        <div class="exercise-board theory-board">
            <div class="prompt-row">
                <div>
                    <p class="prompt-label">@Localizer["TheoryMode"]</p>
                    <h2>@CurrentTheoryTitle</h2>
                </div>
                <div class="prompt-actions">
                    <button class="next-button secondary-button"
                            type="button"
                            disabled="@IsFirstTheoryPage"
                            @onclick="PreviousTheoryPage"
                            aria-label="@Localizer["PreviousTheoryPage"]">
                        @Localizer["Previous"]
                    </button>
                    <button class="next-button"
                            type="button"
                            disabled="@IsLastTheoryPage"
                            @onclick="NextTheoryPage"
                            aria-label="@Localizer["NextTheoryPage"]">
                        @Localizer["Next"]
                    </button>
                </div>
            </div>

            <p class="theory-copy">@CurrentTheoryBody</p>

            @if (CurrentTheoryPage.Visual == TheoryVisual.Staff)
            {
                <div class="theory-visual">
                    <MusicStaff UseAlphabeticalNoteNames="@UseAlphabeticalNoteNames" />
                </div>
            }
            else if (CurrentTheoryPage.Visual == TheoryVisual.TrebleClef)
            {
                <div class="theory-visual">
                    <MusicStaff DisplayedPitch="@(new Pitch(NoteLetter.G, 4))"
                                UseAlphabeticalNoteNames="@UseAlphabeticalNoteNames" />
                    <p class="theory-callout">@Localizer["TheoryTrebleClefCallout"]</p>
                </div>
            }
            else if (CurrentTheoryPage.Visual == TheoryVisual.SingleNote && CurrentTheoryPage.Pitch is { } theoryPitch)
            {
                <div class="theory-visual">
                    <MusicStaff DisplayedPitch="@theoryPitch"
                                UseAlphabeticalNoteNames="@UseAlphabeticalNoteNames" />
                    <p class="theory-callout">@Localizer.Format("TheorySingleNoteCallout", GetPromptName(theoryPitch), theoryPitch.ScientificName.ToLowerInvariant())</p>
                </div>
            }
            else if (CurrentTheoryPage.Visual == TheoryVisual.Keyboard)
            {
                <div class="theory-visual">
                    <PianoKeyboard Pitches="@TrebleClef.BeginnerReadingNotes"
                                   UseAlphabeticalNoteNames="@UseAlphabeticalNoteNames" />
                    <p class="theory-callout">@Localizer["TheoryBlackKeysCallout"]</p>
                </div>
            }
        </div>
    </section>
}
else
{
    <section class="practice-stage">
        <div class="lesson-panel">
            <div class="avatar-chip" aria-label="@Localizer["SelectedAvatarLabel"]">
                <AvatarPortrait Avatar="@selectedAvatar" Size="small" />
            </div>
            <div class="lesson-kicker">@(lesson is null ? string.Empty : Localizer["TrebleClefKicker"])</div>
            <h1>@Localizer["TrebleClefStartTitle"]</h1>

            <button class="back-to-start-button" type="button" @onclick="ReturnToStart">
                @Localizer["BackToStart"]
            </button>

            <div class="mode-switch" role="tablist" aria-label="@Localizer["DrillModeLabel"]">
                <button class="@GetModeClass(DrillMode.NameNote)"
                        type="button"
                        disabled="@IsModeLocked(DrillMode.NameNote)"
                        @onclick="() => SetMode(DrillMode.NameNote)">
                    @Localizer["NameMode"]
                </button>
                <button class="@GetModeClass(DrillMode.PlaceNote)"
                        type="button"
                        disabled="@IsModeLocked(DrillMode.PlaceNote)"
                        @onclick="() => SetMode(DrillMode.PlaceNote)">
                    @Localizer["PlaceMode"]
                </button>
                <button class="@GetModeClass(DrillMode.NameAccidental)"
                        type="button"
                        disabled="@IsModeLocked(DrillMode.NameAccidental)"
                        @onclick="() => SetMode(DrillMode.NameAccidental)">
                    @Localizer["NameAccidentalMode"]
                </button>
                <button class="@GetModeClass(DrillMode.PlaceAccidental)"
                        type="button"
                        disabled="@IsModeLocked(DrillMode.PlaceAccidental)"
                        @onclick="() => SetMode(DrillMode.PlaceAccidental)">
                    @Localizer["PlaceAccidentalMode"]
                </button>
                <button class="@GetModeClass(DrillMode.HearNotePlay)"
                        type="button"
                        disabled="@IsModeLocked(DrillMode.HearNotePlay)"
                        @onclick="() => SetMode(DrillMode.HearNotePlay)">
                    @Localizer["HearPlayMode"]
                </button>
                <button class="@GetModeClass(DrillMode.HearAccidentalPlay)"
                        type="button"
                        disabled="@IsModeLocked(DrillMode.HearAccidentalPlay)"
                        @onclick="() => SetMode(DrillMode.HearAccidentalPlay)">
                    @Localizer["HearAccidentalPlayMode"]
                </button>
                <button class="@GetModeClass(DrillMode.HearNotePlace)"
                        type="button"
                        disabled="@IsModeLocked(DrillMode.HearNotePlace)"
                        @onclick="() => SetMode(DrillMode.HearNotePlace)">
                    @Localizer["HearPlaceMode"]
                </button>
            </div>

            @if (practiceMode == PracticeMode.LearningPath)
            {
                <div class="level-card" aria-live="polite">
                    <div class="level-card-header">
                        <span>@Localizer.Format("LearningLevelLabel", CurrentLevelNumber)</span>
                        <button class="reset-progress-button" type="button" @onclick="ResetProgress">
                            @Localizer["ResetProgress"]
                        </button>
                    </div>
                    <strong>@CurrentDrillTitle</strong>
                    <small>@LearningGoalText</small>
                </div>
            }

            <div class="score-strip" aria-live="polite">
                <span>@Localizer.Format("ScoreCorrect", DisplayCorrectAnswers)</span>
                <span>@Localizer.Format("ScoreTries", DisplayAttempts)</span>
                <span>@Localizer.Format("ScoreStreak", DisplayStreak)</span>
            </div>

            <div class="badge-shelf" aria-label="@Localizer["BadgeShelfLabel"]">
                <div class="badge-shelf-header">@Localizer["BadgeShelfLabel"]</div>
                @if (EarnedBadges.Count == 0)
                {
                    <div class="badge-empty">@Localizer["BadgeShelfEmpty"]</div>
                }
                else
                {
                    <div class="badge-grid">
                        @foreach (var badge in EarnedBadges)
                        {
                            <div class="earned-badge" title="@Localizer[badge.DescriptionKey]">
                                <span>@badge.Icon</span>
                                <small>@Localizer[badge.TitleKey]</small>
                            </div>
                        }
                    </div>
                }
            </div>
        </div>

        <div class="exercise-board">
            <div class="prompt-row">
                <div>
                    <p class="prompt-label">@CurrentDrillTitle</p>
                    <h2>@PromptText</h2>
                </div>
                <div class="prompt-actions">
                    @if (IsHearingMode)
                    {
                        <button class="listen-button" type="button" @onclick="PlayAssignmentNote" aria-label="@Localizer["PlayAssignmentNote"]">
                            @Localizer["PlayAssignmentNote"]
                        </button>
                    }
                    <button class="next-button" type="button" @onclick="AdvanceRound" aria-label="@Localizer["NextNote"]">@Localizer["Next"]</button>
                </div>
            </div>

            @if (ShowsStaff)
            {
                <MusicStaff DisplayedPitch="@DisplayedPitch"
                            IsPlacementMode="@IsPlacementMode"
                            SelectableSteps="@SelectableSteps"
                            SelectedStep="@selectedStep"
                            UseAlphabeticalNoteNames="@UseAlphabeticalNoteNames"
                            OnStepPreviewed="PreviewStaffStep"
                            OnStepSelected="SelectStaffStep" />
            }

            @if (ShowsAccidentalSelector)
            {
                <div class="accidental-selector" role="group" aria-label="@Localizer["AccidentalSelectorLabel"]">
                    <span>@Localizer["AccidentalSelectorLabel"]</span>
                    <button class="@GetAccidentalButtonClass(Accidental.Flat)"
                            type="button"
                            disabled="@(!CanChooseAccidental)"
                            aria-label="@Localizer["AccidentalFlat"]"
                            @onclick="() => SetSelectedAccidental(Accidental.Flat)">♭</button>
                    <button class="@GetAccidentalButtonClass(Accidental.Natural)"
                            type="button"
                            disabled="@(!CanChooseAccidental)"
                            aria-label="@Localizer["AccidentalNatural"]"
                            @onclick="() => SetSelectedAccidental(Accidental.Natural)">♮</button>
                    <button class="@GetAccidentalButtonClass(Accidental.Sharp)"
                            type="button"
                            disabled="@(!CanChooseAccidental)"
                            aria-label="@Localizer["AccidentalSharp"]"
                            @onclick="() => SetSelectedAccidental(Accidental.Sharp)">♯</button>
                    <small>@(CanChooseAccidental ? Localizer["AccidentalSelectorHint"] : Localizer["AccidentalSelectorDisabledHint"])</small>
                </div>
            }

            @if (ShowsKeyboard)
            {
                <PianoKeyboard Pitches="@CurrentKeyboardPitches"
                               HighlightedPitch="@KeyboardHighlightedPitch"
                               UseAlphabeticalNoteNames="@UseAlphabeticalNoteNames"
                               OnPitchPreviewed="PreviewPitch"
                               OnPitchSelected="SelectKeyboardPitch" />
            }

            <div class="@feedbackClass" aria-live="polite">@FeedbackText</div>
        </div>
    </section>
}

@if (isCustomizerOpen)
{
    <div class="customizer-overlay" @onclick="CloseCustomizer" role="dialog" aria-modal="true">
        <div class="customizer-modal" @onclick:stopPropagation>
            <div class="customizer-header">
                <h2>🎨 @Localizer["CustomizeProfileTitle"]</h2>
                <button class="close-modal-button" type="button" @onclick="CloseCustomizer" aria-label="@Localizer["CloseLabel"]">×</button>
            </div>

            <div class="customizer-tabs" role="tablist">
                <button class="@GetTabClass(CustomizerTab.Avatar)" type="button" role="tab" @onclick="() => SetCustomizerTab(CustomizerTab.Avatar)">
                    @Localizer["TabAvatar"]
                </button>
                <button class="@GetTabClass(CustomizerTab.Theme)" type="button" role="tab" @onclick="() => SetCustomizerTab(CustomizerTab.Theme)">
                    @Localizer["TabTheme"]
                </button>
                <button class="@GetTabClass(CustomizerTab.Settings)" type="button" role="tab" @onclick="() => SetCustomizerTab(CustomizerTab.Settings)">
                    @Localizer["TabSettings"]
                </button>
            </div>

            <div class="customizer-content">
                @if (activeCustomizerTab == CustomizerTab.Avatar)
                {
                    <div class="avatar-selection-grid">
                        @foreach (var option in AvatarOptions)
                        {
                            var activeClass = GetAvatarClass(option.Value);
                            <button class="@activeClass"
                                    type="button"
                                    aria-label="@Localizer[option.LabelKey]"
                                    @onclick="() => SetAvatar(option.Value)">
                                <AvatarPortrait Avatar="@option.Value" Size="medium" />
                                <span class="avatar-name">@Localizer[option.LabelKey].Replace(" avatar", "")</span>
                            </button>
                        }
                    </div>
                }
                else if (activeCustomizerTab == CustomizerTab.Theme)
                {
                    <div class="theme-selection-grid">
                        @foreach (var option in VisualThemeOptions)
                        {
                            var activeClass = GetVisualThemeClass(option.Value);
                            <button class="@activeClass"
                                    type="button"
                                    @onclick="() => SetVisualTheme(option.Value)">
                                <span class="theme-preview theme-@option.Value"></span>
                                <span class="theme-name">@Localizer[option.LabelKey]</span>
                            </button>
                        }
                    </div>
                }
                else if (activeCustomizerTab == CustomizerTab.Settings)
                {
                    <div class="settings-pane">
                        <div class="setting-item">
                            <span class="setting-label">@Localizer["NoteNameModeLabel"]</span>
                            <div class="choice-switcher" role="group" aria-label="@Localizer["NoteNameModeLabel"]">
                                <button class="@GetNoteNameModeClass(NoteNameMode.FixedDo)"
                                        type="button"
                                        @onclick="() => SetNoteNameMode(NoteNameMode.FixedDo)">
                                    @Localizer["NoteNameModeFixedDo"]
                                </button>
                                <button class="@GetNoteNameModeClass(NoteNameMode.Alphabetical)"
                                        type="button"
                                        @onclick="() => SetNoteNameMode(NoteNameMode.Alphabetical)">
                                    @Localizer["NoteNameModeAlphabetical"]
                                </button>
                            </div>
                        </div>

                        <div class="setting-item">
                            <span class="setting-label">@Localizer["LanguageSelectorLabel"]</span>
                            <div class="language-switcher" role="group" aria-label="@Localizer["LanguageSelectorLabel"]">
                                @foreach (var culture in AppLocalizer.SupportedCultures)
                                {
                                    <button class="@GetCultureClass(culture.Name)"
                                            type="button"
                                            @onclick="() => ChangeCulture(culture.Name)">
                                        @Localizer.GetCultureDisplayName(culture)
                                    </button>
                                }
                            </div>
                        </div>
                    </div>
                }
            </div>
            
            <div class="customizer-footer">
                <button class="save-modal-button" type="button" @onclick="CloseCustomizer">@Localizer["CloseLabel"]</button>
            </div>
        </div>
    </div>
}
