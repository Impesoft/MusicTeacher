<div class="unlock-toast" role="status" aria-live="polite">
    <div class="toast-badge" aria-hidden="true">@BadgeIcon</div>
    <div class="toast-copy">
        <strong>@Title</strong>
        <span>@Message</span>
        <small>@BadgeTitle · @BadgeDescription</small>
    </div>
    <button type="button" @onclick="OnDismiss" aria-label="@DismissLabel">×</button>
</div>

@code {
    [Parameter]
    public string Title { get; set; } = string.Empty;

    [Parameter]
    public string Message { get; set; } = string.Empty;

    [Parameter]
    public string BadgeTitle { get; set; } = string.Empty;

    [Parameter]
    public string BadgeDescription { get; set; } = string.Empty;

    [Parameter]
    public string BadgeIcon { get; set; } = string.Empty;

    [Parameter]
    public string DismissLabel { get; set; } = string.Empty;

    [Parameter]
    public EventCallback OnDismiss { get; set; }
}
