<div class="@ClassName" aria-hidden="true">
    <svg viewBox="0 0 100 100" class="avatar-svg">
        @if (Avatar == "melody")
        {
            <!-- Melody: Music Note Character -->
            <circle cx="50" cy="50" r="48" fill="#ffe2ed" stroke="#17212b" stroke-width="3" />
            <g class="svg-body">
                <!-- Bowtie -->
                <path d="M 40 78 L 60 70 L 60 86 Z" fill="#ff5f8f" stroke="#17212b" stroke-width="2.5" />
                <path d="M 60 78 L 40 70 L 40 86 Z" fill="#ff5f8f" stroke="#17212b" stroke-width="2.5" />
                <circle cx="50" cy="78" r="5" fill="#ffd76e" stroke="#17212b" stroke-width="2.5" />
                
                <!-- Note Head -->
                <ellipse cx="50" cy="62" rx="19" ry="14" transform="rotate(-15 50 62)" fill="#17212b" />
                <!-- Stem -->
                <rect x="61" y="16" width="6" height="42" fill="#17212b" />
                <!-- Flag -->
                <path d="M 67 16 C 78 16 86 28 83 38 C 81 30 73 24 67 24 Z" fill="#17212b" />
                
                <!-- Face on Note Head (White/Light lines for contrast) -->
                <ellipse cx="44" cy="60" rx="2.5" ry="3.5" fill="#ffffff" />
                <ellipse cx="55" cy="57" rx="2.5" ry="3.5" fill="#ffffff" />
                <path d="M 47 66 Q 50 69 53 64" stroke="#ffffff" stroke-width="2" fill="none" stroke-linecap="round" />
            </g>
        }
        else if (Avatar == "mika")
        {
            <!-- Mika: Cat Kid -->
            <circle cx="50" cy="50" r="48" fill="#fff0b5" stroke="#17212b" stroke-width="3" />
            <!-- Cat Ears grouped for animation -->
            <g class="svg-ear-left">
                <path d="M 22 40 L 12 12 L 36 28 Z" fill="#ff8f7e" stroke="#17212b" stroke-width="3" stroke-linejoin="round" />
                <path d="M 24 36 L 17 18 L 32 28 Z" fill="#ffe2ed" />
            </g>
            <g class="svg-ear-right">
                <path d="M 78 40 L 88 12 L 64 28 Z" fill="#ff8f7e" stroke="#17212b" stroke-width="3" stroke-linejoin="round" />
                <path d="M 76 36 L 83 18 L 68 28 Z" fill="#ffe2ed" />
            </g>
            
            <g class="svg-body">
                <!-- Face -->
                <circle cx="50" cy="56" r="28" fill="#ffd3ac" stroke="#17212b" stroke-width="3" />
                <!-- Bangs -->
                <path d="M 22 50 C 25 32 75 32 78 50 C 65 42 55 46 50 40 C 45 46 35 42 22 50 Z" fill="#7b332f" stroke="#17212b" stroke-width="2.5" />
                <!-- Eyes -->
                <circle cx="38" cy="56" r="3.5" fill="#17212b" />
                <circle cx="62" cy="56" r="3.5" fill="#17212b" />
                <!-- Whiskers -->
                <line x1="20" y1="60" x2="10" y2="58" stroke="#17212b" stroke-width="2" stroke-linecap="round" />
                <line x1="20" y1="64" x2="8" y2="65" stroke="#17212b" stroke-width="2" stroke-linecap="round" />
                <line x1="80" y1="60" x2="90" y2="58" stroke="#17212b" stroke-width="2" stroke-linecap="round" />
                <line x1="80" y1="64" x2="92" y2="65" stroke="#17212b" stroke-width="2" stroke-linecap="round" />
                <!-- Nose & Mouth -->
                <polygon points="50,60 47,57 53,57" fill="#ff5f8f" />
                <path d="M 46 63 Q 50 66 54 63" stroke="#17212b" stroke-width="2" fill="none" stroke-linecap="round" />
            </g>
        }
        else if (Avatar == "nova")
        {
            <!-- Nova: Space Astronaut -->
            <!-- Light space blue background to prevent blending into dark cards -->
            <circle cx="50" cy="50" r="48" fill="#e0e6f8" stroke="#17212b" stroke-width="3" />
            
            <!-- Float group animates antenna and helmet together -->
            <g class="svg-float">
                <!-- Antenna -->
                <line x1="50" y1="20" x2="50" y2="6" stroke="#17212b" stroke-width="3" />
                <circle class="svg-blink" cx="50" cy="5" r="5" fill="#ff5f8f" stroke="#17212b" stroke-width="2.5" />
                
                <g class="svg-body">
                    <!-- Helmet -->
                    <circle cx="50" cy="54" r="34" fill="#ffffff" stroke="#17212b" stroke-width="3" />
                    <!-- Visor -->
                    <ellipse cx="50" cy="52" rx="25" ry="18" fill="#20315f" stroke="#17212b" stroke-width="3" />
                    <!-- Visor Reflection -->
                    <path class="svg-shine" d="M 32 46 A 22 15 0 0 1 68 46" fill="none" stroke="#75d6f2" stroke-width="3" stroke-linecap="round" opacity="0.6" />
                    <!-- Space spark -->
                    <circle cx="65" cy="58" r="2.5" fill="#ffffff" opacity="0.8" />
                </g>
            </g>
        }
        else if (Avatar == "pixel")
        {
            <!-- Pixel: Retro Sprite -->
            <circle cx="50" cy="50" r="48" fill="#e5f9ff" stroke="#17212b" stroke-width="3" />
            <g class="svg-body">
                <!-- Pixel Grid Style Body -->
                <!-- Head -->
                <rect x="22" y="28" width="56" height="48" rx="6" fill="#1f2730" stroke="#17212b" stroke-width="3" />
                <rect x="27" y="33" width="46" height="38" rx="3" fill="#8ee8a2" />
                <!-- Pixels/Crown -->
                <rect x="34" y="20" width="8" height="8" fill="#76e1d8" stroke="#17212b" stroke-width="2.5" />
                <rect x="46" y="16" width="8" height="12" fill="#ffe45c" stroke="#17212b" stroke-width="2.5" />
                <rect x="58" y="20" width="8" height="8" fill="#76e1d8" stroke="#17212b" stroke-width="2.5" />
                <!-- Pixel Eyes (Classed for blink/wink animations) -->
                <rect class="svg-pixel-eye-left" x="36" y="44" width="8" height="8" fill="#17212b" />
                <rect class="svg-pixel-eye-right" x="56" y="44" width="8" height="8" fill="#17212b" />
                <!-- Pixel Mouth -->
                <rect x="44" y="58" width="12" height="4" fill="#17212b" />
            </g>
        }
        else if (Avatar == "luna")
        {
            <!-- Luna: Wizard -->
            <circle cx="50" cy="50" r="48" fill="#f2efff" stroke="#17212b" stroke-width="3" />
            <g class="svg-body">
                <!-- Face -->
                <circle cx="50" cy="62" r="20" fill="#ffd3ac" stroke="#17212b" stroke-width="3" />
                <circle cx="44" cy="60" r="2.5" fill="#17212b" />
                <circle cx="56" cy="60" r="2.5" fill="#17212b" />
                <path d="M 46 68 Q 50 71 54 68" stroke="#17212b" stroke-width="2" fill="none" stroke-linecap="round" />
                
                <!-- Wizard Hat -->
                <path d="M 18 42 L 50 4 L 82 42 Z" fill="#5e458a" stroke="#17212b" stroke-width="3" stroke-linejoin="round" />
                <ellipse cx="50" cy="42" rx="36" ry="6" fill="#b6a8ff" stroke="#17212b" stroke-width="3" />
                
                <!-- Star/Moon Magic transformation container -->
                <g class="svg-star-moon-container">
                    <path class="svg-magical-star" d="M 50 16 L 52 22 L 58 22 L 53 26 L 55 32 L 50 28 L 45 32 L 47 26 L 42 22 L 48 22 Z" fill="#fff27d" />
                    <path class="svg-magical-moon" d="M 45 17 A 8 8 0 0 1 53 29 A 7 7 0 0 0 45 17 Z" fill="#fff27d" style="opacity: 0; transform: scale(0);" />
                </g>
            </g>
        }
        else if (Avatar == "kai")
        {
            <!-- Kai: Robot -->
            <circle cx="50" cy="50" r="48" fill="#eef3ff" stroke="#17212b" stroke-width="3" />
            <!-- Antenna grouped for wiggle animation -->
            <g class="svg-antenna">
                <line x1="50" y1="30" x2="50" y2="12" stroke="#17212b" stroke-width="3" />
                <circle class="svg-blink" cx="50" cy="10" r="4.5" fill="#ff756a" stroke="#17212b" stroke-width="2" />
            </g>
            
            <!-- Bolts on Ears -->
            <rect x="14" y="44" width="8" height="12" rx="2" fill="#17212b" />
            <rect x="78" y="44" width="8" height="12" rx="2" fill="#17212b" />
            
            <g class="svg-body">
                <!-- Head -->
                <rect x="20" y="28" width="60" height="48" rx="10" fill="#ffd76b" stroke="#17212b" stroke-width="3" />
                <!-- Visor -->
                <rect x="28" y="38" width="44" height="18" rx="6" fill="#17212b" stroke="#17212b" stroke-width="2.5" />
                <!-- Glowing Eyes (Classed for pulsing glow) -->
                <circle class="svg-kai-eye" cx="40" cy="47" r="4.5" fill="#75eee2" />
                <circle class="svg-kai-eye" cx="60" cy="47" r="4.5" fill="#75eee2" />
                <!-- Mouth line -->
                <line x1="38" y1="64" x2="62" y2="64" stroke="#17212b" stroke-width="2.5" stroke-dasharray="4 2" />
            </g>
        }
        else if (Avatar == "riko")
        {
            <!-- Riko: Headphones Kid -->
            <circle cx="50" cy="50" r="48" fill="#ffe5df" stroke="#17212b" stroke-width="3" />
            <!-- Headphone Band -->
            <path d="M 26 40 A 26 26 0 0 1 74 40" fill="none" stroke="#17212b" stroke-width="4.5" />
            
            <g class="svg-body">
                <!-- Face -->
                <circle cx="50" cy="56" r="26" fill="#ffd3ac" stroke="#17212b" stroke-width="3" />
                <!-- Cap/Hair -->
                <path d="M 24 50 C 24 24 76 24 76 50 Z" fill="#ff6d9a" stroke="#17212b" stroke-width="3" />
                <path d="M 50 36 L 20 42 L 32 32 Z" fill="#83e7f0" stroke="#17212b" stroke-width="2.5" /> <!-- Visor of cap -->
                
                <!-- Eyes -->
                <circle cx="40" cy="58" r="3" fill="#17212b" />
                <circle cx="60" cy="58" r="3" fill="#17212b" />
                <path class="svg-mouth" d="M 46 64 Q 50 68 54 64" stroke="#17212b" stroke-width="2" fill="none" stroke-linecap="round" />
            </g>
            
            <!-- Ear Cups -->
            <rect class="svg-wiggle" x="16" y="38" width="10" height="24" rx="5" fill="#ff6d9a" stroke="#17212b" stroke-width="3" />
            <rect class="svg-wiggle" x="74" y="38" width="10" height="24" rx="5" fill="#ff6d9a" stroke="#17212b" stroke-width="3" />
        }
        else if (Avatar == "zara")
        {
            <!-- Zara: Teddy Bear -->
            <circle cx="50" cy="50" r="48" fill="#faf0e6" stroke="#17212b" stroke-width="3" />
            
            <!-- Ears grouped for wiggle animation -->
            <g class="svg-ear-left">
                <circle cx="30" cy="34" r="11" fill="#b07d56" stroke="#17212b" stroke-width="3" />
                <circle cx="30" cy="34" r="6" fill="#e5bda1" />
            </g>
            <g class="svg-ear-right">
                <circle cx="70" cy="34" r="11" fill="#b07d56" stroke="#17212b" stroke-width="3" />
                <circle cx="70" cy="34" r="6" fill="#e5bda1" />
            </g>
            
            <g class="svg-body">
                <!-- Head -->
                <circle cx="50" cy="58" r="26" fill="#b07d56" stroke="#17212b" stroke-width="3" />
                
                <!-- Muzzle/Snout -->
                <ellipse cx="50" cy="66" rx="11" ry="8" fill="#ffd3ac" stroke="#17212b" stroke-width="2.5" />
                <!-- Cute prominent capsule-shaped nose -->
                <rect x="45" y="58" width="10" height="6" rx="3" fill="#17212b" />
                <!-- Mouth line -->
                <path d="M 50 64 L 50 67" stroke="#17212b" stroke-width="2.2" stroke-linecap="round" />
                <path d="M 46 67 Q 50 70 54 67" stroke="#17212b" stroke-width="2.2" fill="none" stroke-linecap="round" />
                
                <!-- Eyes (Classed for blinking) -->
                <circle class="svg-zara-eye-left" cx="40" cy="52" r="3.5" fill="#17212b" />
                <circle class="svg-zara-eye-right" cx="60" cy="52" r="3.5" fill="#17212b" />
                <circle cx="39" cy="50.5" r="1" fill="#ffffff" />
                <circle cx="59" cy="50.5" r="1" fill="#ffffff" />
                
                <!-- Blushing Cheeks -->
                <circle cx="34" cy="61" r="3.5" fill="#ffab5c" opacity="0.5" />
                <circle cx="66" cy="61" r="3.5" fill="#ffab5c" opacity="0.5" />
                
                <!-- Bowtie at bottom -->
                <path d="M 40 84 L 60 76 L 60 90 Z" fill="#ff6d9a" stroke="#17212b" stroke-width="2" />
                <path d="M 60 84 L 40 76 L 40 90 Z" fill="#ff6d9a" stroke="#17212b" stroke-width="2" />
                <circle cx="50" cy="83" r="4.5" fill="#ffd76e" stroke="#17212b" stroke-width="2" />
            </g>
        }
        else if (Avatar == "tempo")
        {
            <!-- Tempo: Metronome -->
            <circle cx="50" cy="50" r="48" fill="#fff9d9" stroke="#17212b" stroke-width="3" />
            <g class="svg-body">
                <!-- Pyramidal Body -->
                <path d="M 50 14 L 18 84 L 82 84 Z" fill="#ff9cf0" stroke="#17212b" stroke-width="3" stroke-linejoin="round" />
                <!-- Inner Plate -->
                <path d="M 50 24 L 26 78 L 74 78 Z" fill="#ffffff" stroke="#17212b" stroke-width="2" />
                
                <!-- Metronome scale marks -->
                <line x1="50" y1="36" x2="56" y2="36" stroke="#17212b" stroke-width="1.5" />
                <line x1="50" y1="46" x2="58" y2="46" stroke="#17212b" stroke-width="1.5" />
                <line x1="50" y1="56" x2="60" y2="56" stroke="#17212b" stroke-width="1.5" />
                
                <!-- Pendulum Arm (Moving!) -->
                <g class="svg-swing">
                    <line x1="50" y1="74" x2="38" y2="32" stroke="#17212b" stroke-width="3" stroke-linecap="round" />
                    <!-- Sliding weight -->
                    <rect x="33" y="40" width="10" height="8" rx="2" fill="#ffe878" stroke="#17212b" stroke-width="2" />
                </g>
                
                <!-- Face details on metronome -->
                <circle cx="44" cy="68" r="2.5" fill="#17212b" />
                <circle cx="56" cy="68" r="2.5" fill="#17212b" />
                <path d="M 48 72 Q 50 74 52 72" stroke="#17212b" stroke-width="1.5" fill="none" />
            </g>
        }
        else if (Avatar == "sora")
        {
            <!-- Sora: Fluffy Cloud -->
            <circle cx="50" cy="50" r="48" fill="#eef7ff" stroke="#17212b" stroke-width="3" />
            <!-- Cloud drift container animates wings and body together -->
            <g class="svg-cloud-drift">
                <!-- Wings (Flapping!) -->
                <path class="svg-wing left" d="M 24 50 C 4 44 8 24 22 38 Z" fill="#8fa7ff" stroke="#17212b" stroke-width="2.5" />
                <path class="svg-wing right" d="M 76 50 C 96 44 92 24 78 38 Z" fill="#8fa7ff" stroke="#17212b" stroke-width="2.5" />
                
                <g class="svg-body">
                    <!-- Cloud Outline -->
                    <path d="M 32 68 C 18 68 14 52 26 44 C 20 28 44 16 56 26 C 68 16 92 28 86 44 C 98 52 94 68 80 68 Z" fill="#ffffff" stroke="#17212b" stroke-width="3" stroke-linejoin="round" />
                    <!-- Blushing cheeks -->
                    <circle cx="38" cy="52" r="4" fill="#ff75eee2" opacity="0.6" />
                    <circle cx="74" cy="52" r="4" fill="#ff75eee2" opacity="0.6" />
                    <!-- Cozy eyes & mouth -->
                    <path d="M 42 48 Q 45 52 48 48" stroke="#17212b" stroke-width="2.2" fill="none" stroke-linecap="round" />
                    <path d="M 64 48 Q 67 52 70 48" stroke="#17212b" stroke-width="2.2" fill="none" stroke-linecap="round" />
                    <path d="M 53 54 Q 56 57 59 54" stroke="#17212b" stroke-width="1.8" fill="none" stroke-linecap="round" />
                </g>
            </g>
        }
        else if (Avatar == "nori")
        {
            <!-- Nori: Leaf Elf -->
            <circle cx="50" cy="50" r="48" fill="#f2fff4" stroke="#17212b" stroke-width="3" />
            <!-- Pointy Elf Ears grouped for animation -->
            <g class="svg-ear-left">
                <path d="M 26 54 L 8 46 L 24 40 Z" fill="#ffd3ac" stroke="#17212b" stroke-width="2.5" stroke-linejoin="round" />
            </g>
            <g class="svg-ear-right">
                <path d="M 74 54 L 92 46 L 76 40 Z" fill="#ffd3ac" stroke="#17212b" stroke-width="2.5" stroke-linejoin="round" />
            </g>
            
            <g class="svg-body">
                <!-- Face -->
                <circle cx="50" cy="56" r="24" fill="#ffd3ac" stroke="#17212b" stroke-width="3" />
                <!-- Leaf Hat -->
                <path d="M 50 10 C 72 26 74 42 50 40 C 26 42 28 26 50 10 Z" fill="#8ee8a2" stroke="#17212b" stroke-width="3" stroke-linejoin="round" />
                <path d="M 50 10 L 50 40" stroke="#17212b" stroke-width="1.5" />
                
                <!-- Eyes (Classed for blinking) & Smile -->
                <circle class="svg-nori-eye" cx="42" cy="54" r="2.8" fill="#17212b" />
                <circle class="svg-nori-eye" cx="58" cy="54" r="2.8" fill="#17212b" />
                <path d="M 46 61 Q 50 65 54 61" stroke="#17212b" stroke-width="2" fill="none" stroke-linecap="round" />
            </g>
        }
        else if (Avatar == "aria")
        {
            <!-- Aria: Angel Princess -->
            <circle cx="50" cy="50" r="48" fill="#fff5fb" stroke="#17212b" stroke-width="3" />
            <!-- Angel Wings -->
            <path class="svg-wing left" d="M 22 46 C 4 36 12 18 26 36 Z" fill="#ffffff" stroke="#17212b" stroke-width="2.5" />
            <path class="svg-wing right" d="M 78 46 C 96 36 88 18 74 36 Z" fill="#ffffff" stroke="#17212b" stroke-width="2.5" />
            
            <!-- Pointy Princess Ears grouped for animation -->
            <g class="svg-ear-left">
                <path d="M 26 56 L 16 50 L 25 46 Z" fill="#ffd3ac" stroke="#17212b" stroke-width="2.5" stroke-linejoin="round" />
            </g>
            <g class="svg-ear-right">
                <path d="M 74 56 L 84 50 L 75 46 Z" fill="#ffd3ac" stroke="#17212b" stroke-width="2.5" stroke-linejoin="round" />
            </g>
            
            <g class="svg-body">
                <!-- Face -->
                <circle cx="50" cy="58" r="24" fill="#ffd3ac" stroke="#17212b" stroke-width="3" />
                <!-- Hair -->
                <path d="M 24 54 C 22 28 78 28 76 54 C 68 46 32 46 24 54 Z" fill="#ff8191" stroke="#17212b" stroke-width="2.5" />
                
                <!-- Tiara -->
                <path d="M 38 34 L 42 24 L 50 28 L 58 24 L 62 34 Z" fill="#75d6f2" stroke="#17212b" stroke-width="2.5" stroke-linejoin="round" />
                <circle cx="50" cy="27" r="2" fill="#ffd76b" />
                
                <!-- Eyes & Smile -->
                <path d="M 40 54 A 2 2 0 0 1 44 54" stroke="#17212b" stroke-width="2" fill="none" />
                <path d="M 56 54 A 2 2 0 0 1 60 54" stroke="#17212b" stroke-width="2" fill="none" />
                <path d="M 46 62 Q 50 66 54 62" stroke="#17212b" stroke-width="2" fill="none" stroke-linecap="round" />
            </g>
        }
    </svg>
</div>

@code {
    [Parameter]
    public string Avatar { get; set; } = "melody";

    [Parameter]
    public string Size { get; set; } = "medium";

    [Parameter]
    public bool IsAnimated { get; set; } = false;

    private string ClassName => $"avatar-portrait avatar-{Avatar} is-{Size}{(IsAnimated ? " is-animated" : "")}";
}
